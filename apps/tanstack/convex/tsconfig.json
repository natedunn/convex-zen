{
	/* This TypeScript project config describes the environment that
	 * Convex functions run in and is used to typecheck them.
	 * You can modify it, but some settings are required to use Convex.
	 */
	"compilerOptions": {
		/* These settings are not required by Convex and can be modified. */
		"allowJs": true,
		"strict": true,
		"moduleResolution": "Bundler",
		"jsx": "react-jsx",
		"skipLibCheck": true,
		"allowSyntheticDefaultImports": true,
		"paths": {
			"convex-zen": ["../../../packages/convex-zen/src/client/index.ts"],
			"convex-zen/plugins/system-admin": [
				"../../../packages/convex-zen/src/plugins/system-admin/index.ts"
			],
			"convex-zen/plugins/organization": [
				"../../../packages/convex-zen/src/plugins/organization/index.ts"
			],
			"convex-zen/component": [
				"../../../packages/convex-zen/src/component/index.ts"
			],
			"convex-zen/component/core/gateway": [
				"../../../packages/convex-zen/src/component/core/gateway.ts"
			],
			"convex-zen/component/core/users": [
				"../../../packages/convex-zen/src/component/core/users.ts"
			],
			"convex-zen/component/core-schema-definition": [
				"../../../packages/convex-zen/src/component/core/schemaDefinition.ts"
			],
			"convex-zen/_generated/*": [
				"../../../packages/convex-zen/src/component/_generated/*"
			],
			"convex-zen-example": [
				"../../../packages/convex-zen-example/src/index.ts"
			]
		},

		/* These compiler options are required by Convex */
		"target": "ESNext",
		"lib": ["ES2021", "dom"],
		"forceConsistentCasingInFileNames": true,
		"module": "ESNext",
		"isolatedModules": true,
		"noEmit": true
	},
	"include": ["./**/*"],
	"exclude": ["./_generated"]
}
