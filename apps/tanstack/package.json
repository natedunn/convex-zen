{
	"name": "@convex-zen/tanstack",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "concurrently -k -n web,convex -c blue,green \"pnpm dev:web\" \"convex dev\"",
		"dev:web": "sh -c 'if command -v portless >/dev/null 2>&1; then portless tanstack.convex-zen vite dev; else echo \"portless not found; starting vite dev directly\"; vite dev; fi'",
		"dev:direct": "concurrently -k -n web,convex -c blue,green \"pnpm dev:web:direct\" \"convex dev\"",
		"dev:web:direct": "vite dev",
		"dev:vite": "pnpm dev:web",
		"dev:vite:direct": "pnpm dev:web:direct",
		"build": "vite build",
		"preview": "vite preview",
		"convex:dev": "convex dev"
	},
	"dependencies": {
		"@convex-dev/react-query": "^0.1.0",
		"@tanstack/react-query": "^5.90.21",
		"@tanstack/react-router": "^1.162.1",
		"@tanstack/react-router-devtools": "^1.162.1",
		"@tanstack/react-router-with-query": "^1.130.17",
		"@tanstack/react-start": "^1.162.1",
		"convex": "^1.32.0",
		"convex-zen": "workspace:*",
		"react": "^19.0.0",
		"react-dom": "^19.0.0"
	},
	"devDependencies": {
		"@types/node": "^22.5.4",
		"@types/react": "^19.0.8",
		"@types/react-dom": "^19.0.3",
		"@vitejs/plugin-react": "^4.3.4",
		"concurrently": "^9.2.1",
		"portless": "^0.4.2",
		"typescript": "^5.7.2",
		"vite": "^7.3.1",
		"vite-tsconfig-paths": "^5.1.4"
	}
}
