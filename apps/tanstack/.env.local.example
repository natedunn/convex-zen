# Copy this file to .env.local and fill in your values.
# Run `pnpm -C apps/tanstack convex:dev` to get your deployment URL.
VITE_CONVEX_URL=https://your-deployment.convex.cloud
# App URL when using Portless dev:
# http://tanstack.convex-zen.localhost:1355

# Required for identity JWT mode (one secret env var).
# Generate one:
# openssl rand -base64 32
# Also set this exact value in Convex:
# pnpm -C apps/tanstack exec convex env set CONVEX_ZEN_SECRET "<same value>"
CONVEX_ZEN_SECRET=

# OAuth provider secrets belong in Convex env vars, not .env.local.
# Example:
# pnpm -C apps/tanstack exec convex env set GITHUB_CLIENT_ID "<value>"
# pnpm -C apps/tanstack exec convex env set GITHUB_CLIENT_SECRET "<value>"
# Google callback URL: http://tanstack.convex-zen.localhost:1355/api/auth/callback/google
# GitHub callback URL: http://tanstack.convex-zen.localhost:1355/api/auth/callback/github
# Discord callback URL: http://tanstack.convex-zen.localhost:1355/api/auth/callback/discord
