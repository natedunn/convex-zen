# Copy this file to .env.local and fill in your values.
# Run `pnpm -C apps/next convex:dev` to generate a deployment URL.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# App origin used by auth origin checks (Portless default in the main checkout).
# Linked worktrees use http://<branch>.next.localhost:1355, and PORTLESS_URL is
# trusted automatically during dev.
CONVEX_SITE_URL=http://next.localhost:1355

# Required for identity JWT mode (one secret env var).
# Generate one:
# openssl rand -base64 32
# Also set this exact value in Convex:
# pnpm -C apps/next exec convex env set CONVEX_ZEN_SECRET "<same value>"
CONVEX_ZEN_SECRET=

# OAuth provider secrets belong in Convex env vars, not .env.local.
# Example:
# pnpm -C apps/next exec convex env set GITHUB_CLIENT_ID "<value>"
# pnpm -C apps/next exec convex env set GITHUB_CLIENT_SECRET "<value>"
# Google callback URL: http://next.localhost:1355/api/auth/callback/google
# GitHub callback URL: http://next.localhost:1355/api/auth/callback/github
# Discord callback URL: http://next.localhost:1355/api/auth/callback/discord
