# Copy this file to .env.local and fill in your values.
# Run `pnpm -C apps/next convex:dev` to generate a deployment URL.
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud

# App origin used by auth origin checks (Portless default)
CONVEX_SITE_URL=http://next.convex-zen.localhost:1355

# Required for identity JWT mode (one secret env var).
# Generate one:
# openssl rand -base64 32
# Also set this exact value in Convex:
# pnpm -C apps/next exec convex env set CONVEX_ZEN_SECRET "<same value>"
CONVEX_ZEN_SECRET=

# Optional: OAuth providers (leave blank to disable OAuth)
# CONVEX_GOOGLE_CLIENT_ID=
# CONVEX_GOOGLE_CLIENT_SECRET=
# CONVEX_GITHUB_CLIENT_ID=
# CONVEX_GITHUB_CLIENT_SECRET=
