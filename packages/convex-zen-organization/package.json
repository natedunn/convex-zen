{
  "name": "convex-zen-organization",
  "version": "1.14.1",
  "description": "Organization plugin for convex-zen",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/natedunn/convex-zen.git"
  },
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./gateway": {
      "types": "./src/gateway.ts",
      "import": "./src/gateway.ts"
    },
    "./convex.config": {
      "types": "./src/convex.config.ts",
      "import": "./src/convex.config.ts"
    }
  },
  "scripts": {
    "build": "tsc --noEmit",
    "build:dist": "rm -rf dist tsconfig.build.tsbuildinfo && tsc -p tsconfig.build.json",
    "test": "echo 'no tests'"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./gateway": {
        "types": "./dist/gateway.d.ts",
        "import": "./dist/gateway.js"
      },
      "./convex.config": {
        "types": "./dist/convex.config.d.ts",
        "import": "./dist/convex.config.js"
      }
    }
  },
  "dependencies": {
    "convex": "^1.17.0",
    "convex-zen": "workspace:^"
  },
  "devDependencies": {
    "typescript": "^5.5.0"
  },
  "files": [
    "dist",
    "src",
    "README.md"
  ],
  "license": "Apache-2.0"
}
