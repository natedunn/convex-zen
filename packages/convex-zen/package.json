{
  "name": "convex-zen",
  "version": "1.13.6",
  "description": "Production-grade auth component for Convex",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/natedunn/convex-zen.git"
  },
  "type": "module",
  "bin": {
    "convex-zen": "./dist/cli/index.js"
  },
  "main": "./src/client/index.ts",
  "types": "./src/client/index.ts",
  "exports": {
    ".": {
      "types": "./src/client/index.ts",
      "import": "./src/client/index.ts"
    },
    "./tanstack-start": {
      "types": "./src/client/tanstack-start/index.ts",
      "import": "./src/client/tanstack-start/index.ts"
    },
    "./tanstack-start/identity-jwt": {
      "types": "./src/client/identity-jwt.ts",
      "import": "./src/client/identity-jwt.ts"
    },
    "./tanstack-start/plugins": {
      "types": "./src/client/tanstack-start/plugins.ts",
      "import": "./src/client/tanstack-start/plugins.ts"
    },
    "./tanstack-start/system-admin-plugin": {
      "types": "./src/client/tanstack-start/system-admin-plugin.ts",
      "import": "./src/client/tanstack-start/system-admin-plugin.ts"
    },
    "./react": {
      "types": "./src/client/react.ts",
      "import": "./src/client/react.ts"
    },
    "./framework-adapter": {
      "types": "./src/client/framework-adapter.ts",
      "import": "./src/client/framework-adapter.ts"
    },
    "./expo": {
      "types": "./src/client/expo.ts",
      "import": "./src/client/expo.ts"
    },
    "./next": {
      "types": "./src/client/next/index.ts",
      "import": "./src/client/next/index.ts"
    },
    "./_generated/*.js": {
      "types": "./src/component/_generated/*.ts",
      "import": "./src/component/_generated/*.ts"
    },
    "./core/_generated/*.js": {
      "types": "./src/component/core/_generated/*.ts",
      "import": "./src/component/core/_generated/*.ts"
    },
    "./core/convex.config": {
      "types": "./src/component/core/convex.config.ts",
      "import": "./src/component/core/convex.config.ts"
    },
    "./component": {
      "types": "./src/component/index.ts",
      "import": "./src/component/index.ts"
    },
    "./component/core/gateway": {
      "types": "./src/component/core/gateway.ts",
      "import": "./src/component/core/gateway.ts"
    },
    "./component/core/users": {
      "types": "./src/component/core/users.ts",
      "import": "./src/component/core/users.ts"
    },
    "./component/core-schema-definition": {
      "types": "./src/component/core/schemaDefinition.ts",
      "import": "./src/component/core/schemaDefinition.ts"
    },
    "./convex.config": {
      "types": "./src/component/convex.config.ts",
      "import": "./src/component/convex.config.ts"
    },
    "./plugins/system-admin": {
      "types": "./src/plugins/system-admin/index.ts",
      "import": "./src/plugins/system-admin/index.ts"
    },
    "./plugins/organization": {
      "types": "./src/plugins/organization/index.ts",
      "import": "./src/plugins/organization/index.ts"
    }
  },
  "publishConfig": {
    "main": "./dist/client/index.js",
    "types": "./dist/client/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/client/index.d.ts",
        "import": "./dist/client/index.js"
      },
      "./tanstack-start": {
        "types": "./dist/client/tanstack-start/index.d.ts",
        "import": "./dist/client/tanstack-start/index.js"
      },
      "./tanstack-start/identity-jwt": {
        "types": "./dist/client/identity-jwt.d.ts",
        "import": "./dist/client/identity-jwt.js"
      },
      "./tanstack-start/plugins": {
        "types": "./dist/client/tanstack-start/plugins.d.ts",
        "import": "./dist/client/tanstack-start/plugins.js"
      },
      "./tanstack-start/system-admin-plugin": {
        "types": "./dist/client/tanstack-start/system-admin-plugin.d.ts",
        "import": "./dist/client/tanstack-start/system-admin-plugin.js"
      },
      "./react": {
        "types": "./dist/client/react.d.ts",
        "import": "./dist/client/react.js"
      },
      "./framework-adapter": {
        "types": "./dist/client/framework-adapter.d.ts",
        "import": "./dist/client/framework-adapter.js"
      },
      "./expo": {
        "types": "./dist/client/expo.d.ts",
        "import": "./dist/client/expo.js"
      },
      "./next": {
        "types": "./dist/client/next/index.d.ts",
        "import": "./dist/client/next/index.js"
      },
      "./_generated/*.js": {
        "types": "./dist/component/_generated/*.d.ts",
        "import": "./dist/component/_generated/*.js"
      },
      "./core/_generated/*.js": {
        "types": "./dist/component/core/_generated/*.d.ts",
        "import": "./dist/component/core/_generated/*.js"
      },
      "./core/convex.config": {
        "types": "./dist/component/core/convex.config.d.ts",
        "import": "./dist/component/core/convex.config.js"
      },
      "./component": {
        "types": "./dist/component/index.d.ts",
        "import": "./dist/component/index.js"
      },
      "./component/core/gateway": {
        "types": "./dist/component/core/gateway.d.ts",
        "import": "./dist/component/core/gateway.js"
      },
      "./component/core/users": {
        "types": "./dist/component/core/users.d.ts",
        "import": "./dist/component/core/users.js"
      },
      "./component/core-schema-definition": {
        "types": "./dist/component/core/schemaDefinition.d.ts",
        "import": "./dist/component/core/schemaDefinition.js"
      },
      "./convex.config": {
        "types": "./dist/component/convex.config.d.ts",
        "import": "./dist/component/convex.config.js"
      },
      "./plugins/system-admin": {
        "types": "./dist/plugins/system-admin/index.d.ts",
        "import": "./dist/plugins/system-admin/index.js"
      },
      "./plugins/organization": {
        "types": "./dist/plugins/organization/index.d.ts",
        "import": "./dist/plugins/organization/index.js"
      }
    }
  },
  "scripts": {
    "build": "tsc",
    "build:dist": "rm -rf dist tsconfig.tsbuildinfo && tsc",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@noble/curves": "^1.9.7",
    "@noble/hashes": "^1.8.0",
    "convex": "^1.36.0",
    "hash-wasm": "^4.11.0",
    "jose": "^5.10.0"
  },
  "devDependencies": {
    "@tanstack/react-start": "^1.162.1",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.8",
    "@vitest/coverage-v8": "^2.0.0",
    "convex-test": "^0.0.33",
    "next": "15.5.12",
    "react": "^19.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  },
  "peerDependencies": {
    "@tanstack/react-start": "^1.162.1",
    "convex": "^1.36.0",
    "next": ">=15 <16",
    "react": ">=18.0.0 || >=19.0.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-start": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react": {
      "optional": true
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "license": "Apache-2.0"
}
